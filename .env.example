# 3i Fund Portal — Environment Configuration
# Copy this file to .env and update values for your environment.

# JWT secret — CHANGE THIS in production
JWT_SECRET=your-secure-random-secret-here

# MongoDB connection string (on-prem for now, update for replica set later)
MONGO_URI=mongodb://your-onprem-server:27017
MONGO_DB_NAME=portal_3i

# On-prem calculation server
ONPREM_BASE_URL=http://your-onprem-server:9000

# CORS — S3/CloudFront frontend URL
CORS_ORIGINS=["https://your-portal-domain.com"]

# Debug mode (disable in production)
DEBUG=false
